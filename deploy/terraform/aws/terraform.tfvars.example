region              = "eu-west-1"
environment         = "dev"
project_name        = "jmeter-next"
eks_cluster_version = "1.29"

# Node sizing
controller_instance_type = "t3.large"
eks_node_instance_type   = "t3.xlarge"
eks_node_min_size        = 2
eks_node_max_size        = 10
eks_node_desired_size    = 3
worker_replicas          = 3

# Cost optimization
enable_spot_instances = true
single_nat_gateway    = true  # Set false for production HA

# Observability
enable_vpc_flow_logs    = false
enable_cluster_logging  = false
enable_public_endpoint  = true

# Tags
tags = {
  Team = "performance-engineering"
}
