{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "b3meter - Load Test Observability Dashboard",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Active Runs",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "min": 0,
          "max": 10,
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "jmeter_active_runs{application=\"b3meter\"}",
          "legendFormat": "Active Runs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Samples",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "jmeter_samples_total{application=\"b3meter\"}",
          "legendFormat": "Total Samples",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Response Time Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "jmeter_response_time_seconds{application=\"b3meter\", quantile=\"0.5\"}",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "jmeter_response_time_seconds{application=\"b3meter\", quantile=\"0.9\"}",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "jmeter_response_time_seconds{application=\"b3meter\", quantile=\"0.95\"}",
          "legendFormat": "p95",
          "refId": "C"
        },
        {
          "expr": "jmeter_response_time_seconds{application=\"b3meter\", quantile=\"0.99\"}",
          "legendFormat": "p99",
          "refId": "D"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "rate(jmeter_errors_total{application=\"b3meter\"}[1m]) / (rate(jmeter_samples_total{application=\"b3meter\"}[1m]) > 0)",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "JVM Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"b3meter\", area=\"heap\"}",
          "legendFormat": "Heap Used - {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"b3meter\", area=\"heap\"}",
          "legendFormat": "Heap Committed - {{id}}",
          "refId": "B"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"b3meter\", area=\"heap\"}",
          "legendFormat": "Heap Max - {{id}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"b3meter\"}[1m])",
          "legendFormat": "{{method}} {{uri}} ({{status}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active Workers",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "min": 0,
          "max": 10,
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "jmeter_active_workers{application=\"b3meter\"}",
          "legendFormat": "Active Workers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Samples/sec (Throughput)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "rate(jmeter_samples_total{application=\"b3meter\"}[1m])",
          "legendFormat": "Samples/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Total Runs Started",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "jmeter_runs_total{application=\"b3meter\"}",
          "legendFormat": "Total Runs",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["jmeter", "load-testing", "performance"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "b3meter - Load Test Dashboard",
  "uid": "b3meter-overview",
  "version": 1
}
