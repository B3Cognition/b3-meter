<?xml version="1.0" encoding="UTF-8"?>
<!-- JMeter 6.x JSR223 scripted test plan.
     Exercises Groovy pre/post processors and a JSR223 sampler.
     WARNING: JSR223/Groovy is a known attack surface for XStream deserialization gadget chains.
     The engine-adapter XStreamSecurityPolicy must block org.codehaus.groovy.runtime.MethodClosure. -->
<jmeterTestPlan version="1.2" properties="5.0" jmeter="6.0">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="JSR223 Scripted">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments"/>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Script Users">
        <intProp name="ThreadGroup.num_threads">2</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
          <intProp name="LoopController.loops">2</intProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set Timestamp">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">vars.put("TIMESTAMP", String.valueOf(System.currentTimeMillis()))</stringProp>
          <stringProp name="cacheKey">setTimestamp</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Compute Checksum">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.security.MessageDigest
def md = MessageDigest.getInstance("SHA-256")
def digest = md.digest("payload-${vars.get('TIMESTAMP')}".bytes)
SampleResult.setResponseData(digest.encodeHex().toString(), "UTF-8")
SampleResult.setSuccessful(true)
          </stringProp>
          <stringProp name="cacheKey">computeChecksum</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log Result">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">log.info("Checksum: " + prev.getResponseDataAsString())</stringProp>
          <stringProp name="cacheKey">logResult</stringProp>
        </JSR223PostProcessor>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
